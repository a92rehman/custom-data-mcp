# Required: Google Cloud project ID
BIGQUERY_PROJECT=niete-bq-prod

# Optional: Comma-separated list of priority datasets (for display ordering)
# If omitted, all datasets accessible to the service account are available
# BIGQUERY_DATASETS=RUMI_DB,TaleemHub_DB,tbproddb,odk,mcp_audit,Muawin_Akhuwat_db,Zavia_db

# Required: Path to service account JSON key
GOOGLE_APPLICATION_CREDENTIALS=./niete-bq-prod-48ae5260d1ea.json

# Required: Your name (for audit logs)
TALEEMABAD_USER=Your Name

# Optional: Max bytes billed per query (default: 1GB)
# BIGQUERY_MAX_BYTES=1073741824

# Optional: Default cache TTL in seconds (default: 3600)
# CACHE_TTL_SECONDS=3600

# Optional: Logging level (default: INFO)
# LOG_LEVEL=INFO

# Optional: Audit log destination (default: mcp_audit.activity_log)
# AUDIT_DATASET=mcp_audit
# AUDIT_TABLE=activity_log
